# Nome pubblico mostrato sull'iPhone e nell'interfaccia. Non modifica Bundle ID,
# slug Expo o progetto EAS.
EXPO_PUBLIC_APP_DISPLAY_NAME=Sardinia FireWatch

EXPO_PUBLIC_API_BASE_URL=https://sardegna-firewatch.onrender.com

# Fallback usato solo in sviluppo quando il servizio cartografico commerciale
# non e ancora configurato.
EXPO_PUBLIC_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json

# Token ArcGIS Location Platform / ArcGIS Online limitato alla sola app e ai
# Basemap Styles. Il token viene incorporato nel client e non deve avere
# privilegi amministrativi o accesso a dati privati.
EXPO_PUBLIC_ARCGIS_ACCESS_TOKEN=

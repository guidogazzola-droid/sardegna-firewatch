# Porta HTTP locale
PORT=3000

# Chiave gratuita NASA FIRMS.
# Richiedila su https://firms.modaps.eosdis.nasa.gov/api/map_key/
# La mappa EFFIS funziona anche senza questa chiave; la chiave abilita
# punti interattivi, conteggi, dettagli e notifiche di prossimita.
FIRMS_MAP_KEY=

# Open-Meteo.
# Valori di valutazione/non commerciali:
OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_API_KEY=
# Prima di distribuire un'app a pagamento imposta:
# OPEN_METEO_FORECAST_URL=https://customer-api.open-meteo.com/v1/forecast
# OPEN_METEO_API_KEY=<chiave del piano commerciale>
# OPEN_METEO_REQUIRE_COMMERCIAL=true
OPEN_METEO_REQUIRE_COMMERCIAL=false

# Durata cache lato server, in millisecondi (5 minuti)
CACHE_TTL_MS=300000
